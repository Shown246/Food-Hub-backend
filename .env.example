# Runtime
NODE_ENV=       #development or test
PORT=

# PostgreSQL
DATABASE_URL=
DATABASE_POOL_MAX=

# Better Auth (generate at least 32 random characters for real environments)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Comma-separated browser origins allowed to send credentialed requests
CORS_ORIGINS=

# Cookie and reverse-proxy behavior
COOKIE_SECURE=
COOKIE_SAME_SITE=
TRUST_PROXY=

# Request safety and abuse controls
MAX_BODY_BYTES=
RATE_LIMIT_WINDOW_MS=
AUTH_RATE_LIMIT_MAX=
ORDER_RATE_LIMIT_MAX=
REVIEW_RATE_LIMIT_MAX=
PUBLIC_SEARCH_RATE_LIMIT_MAX=
LOG_LEVEL=

# Interactive API documentation (disable in shared/production environments unless intended)
OPENAPI_DOCS_ENABLED=

# Required by `npm run seed`; choose unique production credentials securely.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional local fixtures. `npm run seed:dev` enables this automatically and
# refuses to run in production. Never reuse this password for a real account.
SEED_DEVELOPMENT_DATA=
SEED_DEVELOPMENT_PASSWORD=
